#!/bin/bash
# Streamlit Cloud runs this after pip install
# Install Chromium + system deps for Playwright PDF rendering

set +e

# Explicitly install libasound2 which Chromium needs but --with-deps may miss
# On Debian trixie, the package may be libasound2t64 instead of libasound2
echo "Installing libasound2 (Chromium dependency)..."
apt-get update -qq 2>/dev/null
apt-get install -y -qq libasound2 2>/dev/null || \
  apt-get install -y -qq libasound2t64 2>/dev/null || true

echo "Installing Playwright Chromium with system dependencies..."
playwright install --with-deps chromium

# Fallback: if --with-deps failed on apt, at least get the browser binaries
if [ $? -ne 0 ]; then
  echo "Playwright --with-deps failed, installing browser binaries only..."
  playwright install chromium
fi

echo "Playwright setup complete."
